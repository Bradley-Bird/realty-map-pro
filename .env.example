# ─────────────────────────────────────────────────────────────
# RealtyMap Pro — Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Google Sign-In ────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project (or select an existing one)
# 3. APIs & Services → OAuth consent screen → configure (External, add test users)
# 4. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#    Application type: Web application
#    Authorized JavaScript origins:
#      http://localhost:5173
#      https://realty-map-pro.netlify.app
#    (Leave Authorized redirect URIs empty for the GIS one-tap flow)
# 5. Copy the "Client ID" value below
VITE_GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── Apple Sign-In ─────────────────────────────────────────────
# 1. Go to https://developer.apple.com → Certificates, Identifiers & Profiles
# 2. Identifiers → Register a new identifier → App IDs
#    Enable capability: Sign In with Apple
# 3. Identifiers → Register a new identifier → Services IDs
#    Description: RealtyMap Pro Web
#    Identifier: com.yourcompany.realtymappro.web  (this becomes VITE_APPLE_CLIENT_ID)
# 4. Click Configure next to Sign In with Apple:
#    Primary App ID: select the App ID from step 2
#    Domains and Subdomains: realty-map-pro.netlify.app
#    Return URLs: https://realty-map-pro.netlify.app
#    (For local dev also add: http://localhost:5173)
# 5. Copy the Services ID identifier below
VITE_APPLE_CLIENT_ID=com.yourcompany.realtymappro.web
